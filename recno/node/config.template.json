{
  "log": {
    "loglevel": "warning",
    "access": "/var/log/recno/access.log",
    "error": "/var/log/recno/error.log"
  },
  "api": {
    "tag": "api",
    "services": [
      "HandlerService",
      "LoggerService",
      "StatsService"
    ]
  },
  "stats": {},
  "policy": {
    "levels": {
      "0": {
        "statsUserUplink": true,
        "statsUserDownlink": true
      }
    },
    "system": {
      "statsInboundUplink": true,
      "statsInboundDownlink": true,
      "statsOutboundUplink": true,
      "statsOutboundDownlink": true
    }
  },
  "inbounds": [
    {
      "listen": "127.0.0.1",
      "port": 6020,
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1"
      },
      "tag": "api-inbound"
    },
    {
      "port": 4430,
      "protocol": "vless",
      "tag": "vless-inbound",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "alpn": [
            "h2",
            "http/1.1"
          ],
          "certificates": [
            {
              "certificateFile": "/etc/recno/certs/fullchain.cer",
              "keyFile": "/etc/recno/certs/private.key"
            }
          ]
        }
      }
    },
    {
      "port": 4431,
      "protocol": "hysteria2",
      "tag": "hy2-inbound-1",
      "settings": {
        "clients": [],
        "ignoreClientBandwidth": false
      },
      "streamSettings": {
        "network": "udp",
        "security": "tls",
        "tlsSettings": {
          "alpn": ["h3"],
          "certificates": [
            {
              "certificateFile": "/etc/recno/certs/fullchain.cer",
              "keyFile": "/etc/recno/certs/private.key"
            }
          ]
        }
      }
    },
    {
      "port": 4432,
      "protocol": "hysteria2",
      "tag": "hy2-inbound-2",
      "settings": {
        "clients": [],
        "ignoreClientBandwidth": false
      },
      "streamSettings": {
        "network": "udp",
        "security": "tls",
        "tlsSettings": {
          "alpn": ["h3"],
          "certificates": [
            {
              "certificateFile": "/etc/recno/certs/fullchain.cer",
              "keyFile": "/etc/recno/certs/private.key"
            }
          ]
        }
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    },
    {
      "protocol": "freedom",
      "tag": "exit-1",
      "settings": {
        "domainStrategy": "UseIP"
      },
      "streamSettings": {
        "sockopt": {
          "mark": 255
        }
      }
    },
    {
      "protocol": "freedom",
      "tag": "exit-2",
      "settings": {
        "domainStrategy": "UseIP"
      },
      "streamSettings": {
        "sockopt": {
          "mark": 254
        }
      }
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "inboundTag": ["api-inbound"],
        "outboundTag": "api",
        "type": "field"
      },
      {
        "type": "field",
        "outboundTag": "block",
        "ip": [
          "geoip:private"
        ]
      },
      {
        "type": "field",
        "inboundTag": ["hy2-inbound-1"],
        "outboundTag": "exit-1"
      },
      {
        "type": "field",
        "inboundTag": ["hy2-inbound-2"],
        "outboundTag": "exit-2"
      },
      {
        "type": "field",
        "domain": [
          "geosite:google"
        ],
        "outboundTag": "direct"
      }
    ]
  }
}
